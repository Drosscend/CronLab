{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CronLab",
  "version": "0.1.0",
  "identifier": "com.drosscend.cronlab",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CronLab",
        "label": "main",
        "width": 600,
        "height": 420,
        "minWidth": 500,
        "minHeight": 350,
        "maxWidth": 800,
        "maxHeight": 600,
        "resizable": true,
        "maximizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
